# Kolaytik — Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env dosyası git'e commit edilmez.

# ── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_DB=kolaytik
POSTGRES_USER=kolaytik
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT ────────────────────────────────────────────────────────────────────
# En az 32 karakter, rastgele oluşturun: openssl rand -base64 48
JWT_KEY=CHANGE_ME_MIN_32_CHARS_SECRET_KEY
JWT_ISSUER=Kolaytik
JWT_AUDIENCE=KolaytikUsers

# ── E-posta (MailKit / SMTP) ───────────────────────────────────────────────
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_USE_STARTTLS=true
EMAIL_USERNAME=noreply@kolaytik.com
EMAIL_PASSWORD=CHANGE_ME
EMAIL_FROM_NAME=Kolaytik
EMAIL_FROM_ADDRESS=noreply@kolaytik.com

# ── CORS / Panel URL ───────────────────────────────────────────────────────
PANEL_URL=https://panel.kolaytik.com
