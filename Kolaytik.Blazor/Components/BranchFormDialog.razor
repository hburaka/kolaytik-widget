<MudDialog>
    <DialogContent>
        @if (!IsEdit)
        {
            @if (IsGlobalAdmin && Tenants is { Count: > 0 })
            {
                <MudSelect T="Guid?" @bind-Value="Model!.TenantId" Label="Firma" Variant="Variant.Outlined"
                           FullWidth="true" Class="mb-3" Required="true">
                    @foreach (var tenant in Tenants)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)tenant.Id)">@tenant.Name</MudSelectItem>
                    }
                </MudSelect>
            }
            else if (CurrentUserTenantId.HasValue)
            {
                <MudAlert Severity="Severity.Info" Class="mb-3">Firma otomatik atandı.</MudAlert>
            }
            <MudTextField @bind-Value="Model!.Name" Label="Şube Adı" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" Required="true" />
            <MudSwitch @bind-Value="Model!.IsActive" Color="Color.Primary" Label="Aktif" />
        }
        else
        {
            <MudTextField @bind-Value="UpdateModel!.Name" Label="Şube Adı" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" Required="true" />
            <MudSwitch @bind-Value="UpdateModel.IsActive" Color="Color.Primary" Label="Aktif" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Kaydet</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public CreateBranchRequest? Model { get; set; }
    [Parameter] public UpdateBranchRequest? UpdateModel { get; set; }
    [Parameter] public IList<TenantResponse>? Tenants { get; set; }
    [Parameter] public bool IsGlobalAdmin { get; set; }
    [Parameter] public Guid? CurrentUserTenantId { get; set; }

    protected override void OnInitialized()
    {
        if (!IsEdit && Model is not null && CurrentUserTenantId.HasValue && !IsGlobalAdmin)
        {
            Model.TenantId = CurrentUserTenantId.Value;
        }
    }

    void Submit()
    {
        if (IsEdit)
        {
            if (string.IsNullOrWhiteSpace(UpdateModel?.Name)) return;
            MudDialog.Close(DialogResult.Ok(UpdateModel));
        }
        else
        {
            if (string.IsNullOrWhiteSpace(Model?.Name)) return;
            MudDialog.Close(DialogResult.Ok(Model));
        }
    }

    void Cancel() => MudDialog.Cancel();
}
