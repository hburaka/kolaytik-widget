<MudDialog>
    <DialogContent>
        @if (IsEdit)
        {
            <MudTextField @bind-Value="UpdateModel!.Label" Label="Etiket" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="UpdateModel.Value" Label="Değer" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" Required="true" />
            <MudSwitch @bind-Value="UpdateModel.IsActive" Color="Color.Primary" Label="Aktif" />
        }
        else
        {
            <MudTextField @bind-Value="Model!.Label" Label="Etiket" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="Model.Value" Label="Değer" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" Required="true" />
            <MudSwitch @bind-Value="Model.IsActive" Color="Color.Primary" Label="Aktif" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Kaydet</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public CreateListItemRequest? Model { get; set; }
    [Parameter] public UpdateListItemRequest? UpdateModel { get; set; }

    void Submit()
    {
        if (IsEdit)
        {
            if (string.IsNullOrWhiteSpace(UpdateModel?.Label)) return;
            MudDialog.Close(DialogResult.Ok(UpdateModel));
        }
        else
        {
            if (string.IsNullOrWhiteSpace(Model?.Label)) return;
            MudDialog.Close(DialogResult.Ok(Model));
        }
    }

    void Cancel() => MudDialog.Cancel();
}
