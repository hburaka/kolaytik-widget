<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_name" Label="Sektör Adı" Variant="Variant.Outlined"
                      FullWidth="true" Class="mb-3" Required="true" />
        @if (IsEdit)
        {
            <MudSwitch @bind-Value="_isActive" Color="Color.Primary" Label="Aktif" />
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Kaydet</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public CreateSectorRequest? Model { get; set; }
    [Parameter] public UpdateSectorRequest? UpdateModel { get; set; }

    private string _name = string.Empty;
    private bool _isActive = true;

    protected override void OnParametersSet()
    {
        if (IsEdit && UpdateModel is not null)
        {
            _name = UpdateModel.Name;
            _isActive = UpdateModel.IsActive;
        }
        else if (!IsEdit && Model is not null)
        {
            _name = Model.Name;
        }
    }

    void Submit()
    {
        if (string.IsNullOrWhiteSpace(_name)) return;

        if (IsEdit)
        {
            UpdateModel!.Name = _name;
            UpdateModel.IsActive = _isActive;
            MudDialog.Close(DialogResult.Ok(UpdateModel));
        }
        else
        {
            Model!.Name = _name;
            MudDialog.Close(DialogResult.Ok(Model));
        }
    }

    void Cancel() => MudDialog.Cancel();
}
