<MudDialog>
    <DialogContent>
        @if (!IsEdit)
        {
            <MudTextField @bind-Value="Model!.Name" Label="Firma Adı" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="Model.AuthorizedName" Label="Yetkili Adı" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" />
            <MudTextField @bind-Value="Model.Email" Label="E-mail" InputType="InputType.Email"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-3" />
            <MudTextField @bind-Value="Model.Phone" Label="Telefon" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" />
            <MudTextField @bind-Value="Model.TaxNumber" Label="Vergi No" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" />
            <MudTextField @bind-Value="Model.Address" Label="Adres" Variant="Variant.Outlined"
                          FullWidth="true" Lines="2" />
        }
        else
        {
            <MudTextField @bind-Value="UpdateModel!.Name" Label="Firma Adı" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="UpdateModel.AuthorizedName" Label="Yetkili Adı" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" />
            <MudTextField @bind-Value="UpdateModel.Email" Label="E-mail" InputType="InputType.Email"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-3" />
            <MudTextField @bind-Value="UpdateModel.Phone" Label="Telefon" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" />
            <MudTextField @bind-Value="UpdateModel.TaxNumber" Label="Vergi No" Variant="Variant.Outlined"
                          FullWidth="true" Class="mb-3" />
            <MudTextField @bind-Value="UpdateModel.Address" Label="Adres" Variant="Variant.Outlined"
                          FullWidth="true" Lines="2" Class="mb-3" />
            <MudSelect @bind-Value="UpdateModel.Status" Label="Durum" Variant="Variant.Outlined" FullWidth="true">
                <MudSelectItem Value="@("Active")">Aktif</MudSelectItem>
                <MudSelectItem Value="@("Passive")">Pasif</MudSelectItem>
                <MudSelectItem Value="@("Suspended")">Askıda</MudSelectItem>
            </MudSelect>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Kaydet</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public CreateTenantRequest? Model { get; set; }
    [Parameter] public UpdateTenantRequest? UpdateModel { get; set; }

    void Submit()
    {
        if (IsEdit)
        {
            if (string.IsNullOrWhiteSpace(UpdateModel?.Name)) return;
            MudDialog.Close(DialogResult.Ok(UpdateModel));
        }
        else
        {
            if (string.IsNullOrWhiteSpace(Model?.Name)) return;
            MudDialog.Close(DialogResult.Ok(Model));
        }
    }

    void Cancel() => MudDialog.Cancel();
}
