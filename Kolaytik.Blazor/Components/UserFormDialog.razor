<MudDialog>
    <DialogContent>
        @if (!IsEdit)
        {
            <MudTextField @bind-Value="Model!.Email" Label="E-mail" InputType="InputType.Email"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-3" Required="true" />
            <MudTextField @bind-Value="Model.Password" Label="Şifre" InputType="InputType.Password"
                          Variant="Variant.Outlined" FullWidth="true" Class="mb-3" Required="true" />
            <MudSelect @bind-Value="Model.Role" Label="Rol" Variant="Variant.Outlined" FullWidth="true" Class="mb-3">
                @if (IsGlobalAdmin)
                {
                    <MudSelectItem Value="@("SuperAdmin")">SuperAdmin</MudSelectItem>
                    <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                }
                <MudSelectItem Value="@("TenantAdmin")">TenantAdmin</MudSelectItem>
                <MudSelectItem Value="@("BranchManager")">BranchManager</MudSelectItem>
                <MudSelectItem Value="@("BranchUser")">BranchUser</MudSelectItem>
            </MudSelect>
            @if (IsGlobalAdmin && Tenants is { Count: > 0 })
            {
                <MudSelect T="Guid?" @bind-Value="Model.TenantId" Label="Firma" Variant="Variant.Outlined"
                           FullWidth="true" Class="mb-3">
                    @foreach (var tenant in Tenants)
                    {
                        <MudSelectItem T="Guid?" Value="@((Guid?)tenant.Id)">@tenant.Name</MudSelectItem>
                    }
                </MudSelect>
            }
            @if (Branches is { Count: > 0 } && (Model.Role == "BranchManager" || Model.Role == "BranchUser"))
            {
                <MudSelect T="Guid" MultiSelection="true" @bind-SelectedValues="_createSelectedBranchIds"
                           Label="Şube Ataması" Variant="Variant.Outlined" FullWidth="true" Class="mb-3">
                    @foreach (var branch in Branches)
                    {
                        <MudSelectItem T="Guid" Value="@branch.Id">@branch.Name</MudSelectItem>
                    }
                </MudSelect>
            }
        }
        else
        {
            <MudSelect @bind-Value="UpdateModel!.Role" Label="Rol" Variant="Variant.Outlined" FullWidth="true" Class="mb-3">
                @if (IsGlobalAdmin)
                {
                    <MudSelectItem Value="@("SuperAdmin")">SuperAdmin</MudSelectItem>
                    <MudSelectItem Value="@("Admin")">Admin</MudSelectItem>
                }
                <MudSelectItem Value="@("TenantAdmin")">TenantAdmin</MudSelectItem>
                <MudSelectItem Value="@("BranchManager")">BranchManager</MudSelectItem>
                <MudSelectItem Value="@("BranchUser")">BranchUser</MudSelectItem>
            </MudSelect>
            <MudSelect @bind-Value="UpdateModel.Status" Label="Durum" Variant="Variant.Outlined" FullWidth="true" Class="mb-3">
                <MudSelectItem Value="@("Active")">Aktif</MudSelectItem>
                <MudSelectItem Value="@("Passive")">Pasif</MudSelectItem>
            </MudSelect>
            @if (Branches is { Count: > 0 })
            {
                <MudSelect T="Guid" MultiSelection="true" @bind-SelectedValues="_editSelectedBranchIds"
                           Label="Şube Ataması" Variant="Variant.Outlined" FullWidth="true" Class="mb-3">
                    @foreach (var branch in Branches)
                    {
                        <MudSelectItem T="Guid" Value="@branch.Id">@branch.Name</MudSelectItem>
                    }
                </MudSelect>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">İptal</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit">Kaydet</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public CreateUserRequest? Model { get; set; }
    [Parameter] public UpdateUserRequest? UpdateModel { get; set; }
    [Parameter] public IList<TenantResponse>? Tenants { get; set; }
    [Parameter] public IList<BranchResponse>? Branches { get; set; }
    [Parameter] public bool IsGlobalAdmin { get; set; }

    private IEnumerable<Guid> _createSelectedBranchIds { get; set; } = new HashSet<Guid>();
    private IEnumerable<Guid> _editSelectedBranchIds
    {
        get => _editSelectedBranchIdsBackingField;
        set
        {
            _editSelectedBranchIdsBackingField = value;
            if (UpdateModel is not null)
                UpdateModel.BranchIds = value.ToList();
        }
    }
    private IEnumerable<Guid> _editSelectedBranchIdsBackingField = new HashSet<Guid>();

    protected override void OnParametersSet()
    {
        if (IsEdit && UpdateModel is not null)
            _editSelectedBranchIdsBackingField = new HashSet<Guid>(UpdateModel.BranchIds);
    }

    void Submit()
    {
        if (IsEdit)
        {
            MudDialog.Close(DialogResult.Ok(UpdateModel));
        }
        else
        {
            if (Model is not null)
                Model.BranchIds = _createSelectedBranchIds.ToList();
            MudDialog.Close(DialogResult.Ok(Model));
        }
    }

    void Cancel() => MudDialog.Cancel();
}
