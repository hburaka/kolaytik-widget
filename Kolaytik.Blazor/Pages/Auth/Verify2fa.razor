@page "/auth/verify-2fa"
@layout EmptyLayout
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage

<PageTitle>İki Faktörlü Doğrulama — Kolaytik</PageTitle>

<MudGrid Justify="Justify.Center" Style="min-height:100vh; align-items:center;">
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="4">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6" Align="Align.Center">İki Faktörlü Doğrulama</MudText>
                    <MudText Typo="Typo.body2" Align="Align.Center" Color="Color.Secondary">
                        Authenticator uygulamanızdaki 6 haneli kodu girin
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                }
                <MudTextField @bind-Value="_code" Label="Doğrulama Kodu" InputType="InputType.Text"
                              Variant="Variant.Outlined" FullWidth="true" Class="mb-4"
                              Placeholder="123456" MaxLength="6" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           OnClick="VerifyAsync" Disabled="_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Doğrula
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string _code = string.Empty;
    private string _error = string.Empty;
    private bool _loading;
    private string? _preAuthToken;

    protected override async Task OnInitializedAsync()
    {
        _preAuthToken = await LocalStorage.GetItemAsStringAsync("preAuthToken");
        if (string.IsNullOrEmpty(_preAuthToken))
            Nav.NavigateTo("/login");
    }

    private async Task VerifyAsync()
    {
        _error = string.Empty;
        if (string.IsNullOrEmpty(_preAuthToken))
        {
            Nav.NavigateTo("/login");
            return;
        }

        _loading = true;
        try
        {
            var result = await AuthService.Verify2faAsync(new Verify2faRequest
            {
                PreAuthToken = _preAuthToken,
                TotpCode = _code.Trim()
            });

            if (result is null)
            {
                _error = "Doğrulama başarısız.";
                return;
            }

            await LocalStorage.RemoveItemAsync("preAuthToken");
            Nav.NavigateTo("/");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
