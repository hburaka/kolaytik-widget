@page "/branches/create"
@page "/branches/{Id:guid}/edit"
@attribute [Authorize(Roles = "SuperAdmin,Admin,TenantAdmin")]
@inject IBranchService BranchService
@inject ITenantService TenantService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject KolaytikAuthStateProvider AuthStateProvider

<PageTitle>@(IsEdit ? "Şubeyi Düzenle" : "Yeni Şube")</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

<MudPaper Class="pa-6" Style="max-width:640px">
    <MudText Typo="Typo.h6" Class="mb-4">@(IsEdit ? "Şubeyi Düzenle" : "Yeni Şube")</MudText>

    @if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _errorMessage = null)">@_errorMessage</MudAlert>
    }

    @if (!IsEdit)
    {
        @if (_isGlobalAdmin && _tenants.Count > 0)
        {
            <MudSelect T="Guid?" @bind-Value="_tenantId" Label="Firma" Variant="Variant.Outlined"
                       FullWidth="true" Class="mb-3" Required="true">
                @foreach (var tenant in _tenants)
                {
                    <MudSelectItem T="Guid?" Value="@((Guid?)tenant.Id)">@tenant.Name</MudSelectItem>
                }
            </MudSelect>
        }
        else
        {
            <MudAlert Severity="Severity.Info" Class="mb-3">Firma otomatik atandı.</MudAlert>
        }
    }

    <MudTextField @bind-Value="_name" Label="Şube Adı" Variant="Variant.Outlined"
                  FullWidth="true" Class="mb-3" Required="true" />
    <MudSwitch @bind-Value="_isActive" Color="Color.Primary" Label="Aktif" />

    <div class="d-flex gap-3 mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SubmitAsync" Disabled="_saving">
            @(_saving ? "Kaydediliyor..." : "Kaydet")
        </MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">İptal</MudButton>
    </div>
</MudPaper>

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsEdit => Id.HasValue;
    private bool _saving;
    private string? _errorMessage;
    private string _name = string.Empty;
    private bool _isActive = true;
    private Guid? _tenantId;
    private bool _isGlobalAdmin;
    private IList<TenantResponse> _tenants = new List<TenantResponse>();

    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Şubeler", "/branches"),
            new(IsEdit ? "Düzenle" : "Yeni", null, disabled: true)
        };

        var role = await AuthStateProvider.GetRoleAsync();
        _isGlobalAdmin = role == "SuperAdmin" || role == "Admin";

        if (IsEdit)
        {
            var branch = await BranchService.GetBranchAsync(Id!.Value);
            if (branch is null) { Nav.NavigateTo("/branches"); return; }
            _name = branch.Name;
            _isActive = branch.IsActive;
        }
        else
        {
            if (_isGlobalAdmin)
            {
                var tenantsResult = await TenantService.GetTenantsAsync(new PagedRequest { Page = 1, PageSize = 200 });
                _tenants = tenantsResult?.Items?.ToList() ?? new List<TenantResponse>();
            }
            else
            {
                _tenantId = await AuthStateProvider.GetTenantIdAsync();
            }
        }
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _errorMessage = "Şube adı zorunludur.";
            return;
        }

        _saving = true;
        _errorMessage = null;
        try
        {
            if (IsEdit)
            {
                var result = await BranchService.UpdateBranchAsync(Id!.Value, new UpdateBranchRequest { Name = _name, IsActive = _isActive });
                if (result is not null) { Snackbar.Add("Şube güncellendi.", Severity.Success); Nav.NavigateTo("/branches"); }
                else { _errorMessage = "Şube güncellenemedi."; }
            }
            else
            {
                var req = new CreateBranchRequest { Name = _name, IsActive = _isActive };
                if (_isGlobalAdmin)
                    req.TenantId = _tenantId;
                else
                    req.TenantId = _tenantId;

                var result = await BranchService.CreateBranchAsync(req);
                if (result is not null) { Snackbar.Add("Şube oluşturuldu.", Severity.Success); Nav.NavigateTo("/branches"); }
                else { _errorMessage = "Şube oluşturulamadı."; }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/branches");
}
