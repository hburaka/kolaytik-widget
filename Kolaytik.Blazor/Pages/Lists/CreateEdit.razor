@page "/lists/create"
@page "/lists/{Id:guid}/edit"
@attribute [Authorize]
@inject IListService ListService
@inject IBranchService BranchService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Listeyi Düzenle" : "Yeni Liste")</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

<MudPaper Class="pa-6" Style="max-width:640px">
    <MudText Typo="Typo.h6" Class="mb-4">@(IsEdit ? "Listeyi Düzenle" : "Yeni Liste")</MudText>

    @if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _errorMessage = null)">@_errorMessage</MudAlert>
    }

    <MudTextField @bind-Value="_name" Label="Liste Adı" Variant="Variant.Outlined"
                  FullWidth="true" Class="mb-3" Required="true" />
    <MudTextField @bind-Value="_description" Label="Açıklama" Variant="Variant.Outlined"
                  FullWidth="true" Class="mb-3" Lines="3" />

    @if (!IsEdit && _branches.Count > 0)
    {
        <MudSelect T="Guid?" @bind-Value="_branchId" Label="Şube (opsiyonel)"
                   Variant="Variant.Outlined" FullWidth="true" Clearable="true">
            @foreach (var branch in _branches)
            {
                <MudSelectItem T="Guid?" Value="@((Guid?)branch.Id)">@branch.Name</MudSelectItem>
            }
        </MudSelect>
    }

    <div class="d-flex gap-3 mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SubmitAsync" Disabled="_saving">
            @(_saving ? "Kaydediliyor..." : "Kaydet")
        </MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">İptal</MudButton>
    </div>
</MudPaper>

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsEdit => Id.HasValue;
    private bool _saving;
    private string? _errorMessage;
    private string _name = string.Empty;
    private string? _description;
    private Guid? _branchId;
    private IList<BranchResponse> _branches = new List<BranchResponse>();

    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Listeler", "/lists"),
            new(IsEdit ? "Düzenle" : "Yeni", null, disabled: true)
        };

        if (IsEdit)
        {
            var list = await ListService.GetListAsync(Id!.Value);
            if (list is null) { Nav.NavigateTo("/lists"); return; }
            _name = list.Name;
            _description = list.Description;
        }
        else
        {
            var branchesResult = await BranchService.GetBranchesAsync(new PagedRequest { Page = 1, PageSize = 200 });
            _branches = branchesResult?.Items?.ToList() ?? new List<BranchResponse>();
        }
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _errorMessage = "Liste adı zorunludur.";
            return;
        }

        _saving = true;
        _errorMessage = null;
        try
        {
            if (IsEdit)
            {
                var result = await ListService.UpdateListAsync(Id!.Value, new UpdateListRequest { Name = _name, Description = _description });
                if (result is not null) { Snackbar.Add("Liste güncellendi.", Severity.Success); Nav.NavigateTo("/lists"); }
                else { _errorMessage = "Liste güncellenemedi."; }
            }
            else
            {
                var result = await ListService.CreateListAsync(new CreateListRequest { Name = _name, Description = _description, BranchId = _branchId });
                if (result is not null) { Snackbar.Add("Liste oluşturuldu.", Severity.Success); Nav.NavigateTo("/lists"); }
                else { _errorMessage = "Liste oluşturulamadı."; }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/lists");
}
