@page "/lists"
@attribute [Authorize]
@inject IListService ListService
@inject IBranchService BranchService
@inject ITenantService TenantService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject KolaytikAuthStateProvider AuthStateProvider

<PageTitle>Listeler</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Listeler</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" sm="8">
            <MudTextField @bind-Value="_search" Label="Ara..." Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true"
                          DebounceInterval="400" OnDebounceIntervalElapsed="LoadLists"
                          Variant="Variant.Outlined" />
        </MudItem>
        <MudItem xs="12" sm="4" Class="d-flex align-center justify-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                Yeni Liste
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudDataGrid T="ListResponse" Items="_items" Loading="_loading"
             SortMode="SortMode.None" Filterable="false" Dense="true">
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Liste Adı" />
        <PropertyColumn Property="x => x.BranchName" Title="Şube" />
        <PropertyColumn Property="x => x.ItemCount" Title="Eleman Sayısı" CellStyle="width:130px" />
        <PropertyColumn Property="x => x.CreatedAt" Title="Oluşturulma" Format="dd.MM.yyyy" CellStyle="width:130px" />
        <TemplateColumn Title="İşlemler" CellStyle="width:140px">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Visibility" Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo($"/lists/{context.Item.Id}"))" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context.Item))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error"
                               OnClick="@(() => DeleteListAsync(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <PagerContent>
        <MudDataGridPager T="ListResponse" />
    </PagerContent>
    <NoRecordsContent>
        <MudText>Kayıt bulunamadı.</MudText>
    </NoRecordsContent>
</MudDataGrid>

@code {
    private IEnumerable<ListResponse> _items = Enumerable.Empty<ListResponse>();
    private IList<BranchResponse> _branches = new List<BranchResponse>();
    private IList<TenantResponse> _tenants = new List<TenantResponse>();
    private bool _loading;
    private bool _isGlobalAdmin;
    private string _search = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var role = await AuthStateProvider.GetRoleAsync();
        _isGlobalAdmin = role == "SuperAdmin" || role == "Admin";

        await Task.WhenAll(LoadLists(), LoadSupportData());
    }

    private async Task LoadSupportData()
    {
        var branchTask = BranchService.GetBranchesAsync(new PagedRequest { Page = 1, PageSize = 200 });
        var tenantTask = _isGlobalAdmin
            ? TenantService.GetTenantsAsync(new PagedRequest { Page = 1, PageSize = 200 })
            : Task.FromResult<PagedResult<TenantResponse>?>(null);

        await Task.WhenAll(branchTask, tenantTask);
        _branches = (await branchTask)?.Items?.ToList() ?? new List<BranchResponse>();
        _tenants = (await tenantTask)?.Items?.ToList() ?? new List<TenantResponse>();
    }

    private async Task LoadLists()
    {
        _loading = true;
        try
        {
            var result = await ListService.GetListsAsync(new PagedRequest { Page = 1, PageSize = 50, Search = _search });
            _items = result?.Items ?? Enumerable.Empty<ListResponse>();
        }
        finally { _loading = false; }
    }

    private async Task OpenCreateDialog()
    {
        var parameters = new DialogParameters<ListFormDialog>
        {
            { x => x.IsEdit, false },
            { x => x.IsGlobalAdmin, _isGlobalAdmin },
            { x => x.Model, new CreateListRequest() },
            { x => x.Tenants, _tenants },
            { x => x.Branches, _branches }
        };
        var dialog = await DialogService.ShowAsync<ListFormDialog>("Yeni Liste", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var req = (CreateListRequest)result.Data!;
            var created = await ListService.CreateListAsync(req);
            if (created is not null)
            {
                Snackbar.Add("Liste oluşturuldu.", Severity.Success);
                await LoadLists();
            }
            else
            {
                Snackbar.Add("Liste oluşturulamadı.", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(ListResponse list)
    {
        var model = new UpdateListRequest { Name = list.Name, Description = list.Description };
        var parameters = new DialogParameters<ListFormDialog>
        {
            { x => x.IsEdit, true },
            { x => x.UpdateModel, model }
        };
        var dialog = await DialogService.ShowAsync<ListFormDialog>("Listeyi Düzenle", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var req = (UpdateListRequest)result.Data!;
            var updated = await ListService.UpdateListAsync(list.Id, req);
            if (updated is not null)
            {
                Snackbar.Add("Liste güncellendi.", Severity.Success);
                await LoadLists();
            }
            else
            {
                Snackbar.Add("Liste güncellenemedi.", Severity.Error);
            }
        }
    }

    private async Task DeleteListAsync(ListResponse list)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, $"'{list.Name}' listesi silinecek. Emin misiniz?" }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Onayla", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var success = await ListService.DeleteListAsync(list.Id);
            if (success)
            {
                Snackbar.Add("Liste silindi.", Severity.Success);
                await LoadLists();
            }
            else
            {
                Snackbar.Add("Liste silinemedi.", Severity.Error);
            }
        }
    }
}
