@page "/profile/change-password"
@attribute [Authorize]
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>Şifre Değiştir</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Şifre Değiştir</MudText>

<MudGrid>
    <MudItem xs="12" sm="8" md="5">
        <MudCard>
            <MudCardContent>
                @if (!string.IsNullOrEmpty(_error))
                {
                    <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
                }
                <MudTextField @bind-Value="_currentPassword" Label="Mevcut Şifre"
                              InputType="InputType.Password" Variant="Variant.Outlined"
                              FullWidth="true" Class="mb-3" />
                <MudTextField @bind-Value="_newPassword" Label="Yeni Şifre"
                              InputType="InputType.Password" Variant="Variant.Outlined"
                              FullWidth="true" Class="mb-3" />
                <MudTextField @bind-Value="_confirmPassword" Label="Yeni Şifre (Tekrar)"
                              InputType="InputType.Password" Variant="Variant.Outlined"
                              FullWidth="true" Class="mb-4" />
            </MudCardContent>
            <MudCardActions>
                <MudButton Variant="Variant.Outlined" OnClick="@(() => Nav.NavigateTo("/"))">İptal</MudButton>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="ChangeAsync" Disabled="_loading">
                    @if (_loading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Değiştir
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string _currentPassword = string.Empty;
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string _error = string.Empty;
    private bool _loading;

    private async Task ChangeAsync()
    {
        _error = string.Empty;

        if (_newPassword != _confirmPassword)
        {
            _error = "Yeni şifreler eşleşmiyor.";
            return;
        }

        if (_newPassword.Length < 8)
        {
            _error = "Şifre en az 8 karakter olmalıdır.";
            return;
        }

        _loading = true;
        try
        {
            var success = await AuthService.ChangePasswordAsync(new ChangePasswordRequest
            {
                CurrentPassword = _currentPassword,
                NewPassword = _newPassword
            });

            if (!success)
            {
                _error = "Mevcut şifre hatalı veya işlem başarısız.";
                return;
            }

            Snackbar.Add("Şifre değiştirildi. Lütfen tekrar giriş yapın.", Severity.Success);
            await AuthService.LogoutAsync();
            Nav.NavigateTo("/login");
        }
        finally
        {
            _loading = false;
        }
    }
}
