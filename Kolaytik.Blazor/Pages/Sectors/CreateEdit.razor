@page "/sectors/create"
@page "/sectors/{Id:guid}/edit"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@inject ISectorService SectorService
@inject ISnackbar Snackbar
@inject NavigationManager Nav

<PageTitle>@(IsEdit ? "Sektörü Düzenle" : "Yeni Sektör")</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="mb-4" />

<MudPaper Class="pa-6" Style="max-width:640px">
    <MudText Typo="Typo.h6" Class="mb-4">@(IsEdit ? "Sektörü Düzenle" : "Yeni Sektör")</MudText>

    @if (_errorMessage is not null)
    {
        <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true"
                  CloseIconClicked="@(() => _errorMessage = null)">@_errorMessage</MudAlert>
    }

    <MudTextField @bind-Value="_name" Label="Sektör Adı" Variant="Variant.Outlined"
                  FullWidth="true" Class="mb-3" Required="true" />
    @if (IsEdit)
    {
        <MudSwitch @bind-Value="_isActive" Color="Color.Primary" Label="Aktif" Class="mb-3" />
    }

    <div class="d-flex gap-3 mt-4">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="SubmitAsync" Disabled="_saving">
            @(_saving ? "Kaydediliyor..." : "Kaydet")
        </MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="Cancel">İptal</MudButton>
    </div>
</MudPaper>

@code {
    [Parameter] public Guid? Id { get; set; }
    private bool IsEdit => Id.HasValue;
    private bool _saving;
    private string? _errorMessage;
    private string _name = string.Empty;
    private bool _isActive = true;

    private List<BreadcrumbItem> _breadcrumbs = new();

    protected override async Task OnInitializedAsync()
    {
        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Sektörler", "/sectors"),
            new(IsEdit ? "Düzenle" : "Yeni", null, disabled: true)
        };

        if (IsEdit)
        {
            var sector = await SectorService.GetSectorAsync(Id!.Value);
            if (sector is null) { Nav.NavigateTo("/sectors"); return; }
            _name = sector.Name;
            _isActive = sector.IsActive;
        }
    }

    private async Task SubmitAsync()
    {
        if (string.IsNullOrWhiteSpace(_name))
        {
            _errorMessage = "Sektör adı zorunludur.";
            return;
        }

        _saving = true;
        _errorMessage = null;
        try
        {
            if (IsEdit)
            {
                var result = await SectorService.UpdateSectorAsync(Id!.Value, new UpdateSectorRequest { Name = _name, IsActive = _isActive });
                if (result is not null) { Snackbar.Add("Sektör güncellendi.", Severity.Success); Nav.NavigateTo("/sectors"); }
                else { _errorMessage = "Sektör güncellenemedi."; }
            }
            else
            {
                var result = await SectorService.CreateSectorAsync(new CreateSectorRequest { Name = _name });
                if (result is not null) { Snackbar.Add("Sektör oluşturuldu.", Severity.Success); Nav.NavigateTo("/sectors"); }
                else { _errorMessage = "Sektör oluşturulamadı."; }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void Cancel() => Nav.NavigateTo("/sectors");
}
