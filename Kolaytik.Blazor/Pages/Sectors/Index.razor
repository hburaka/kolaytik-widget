@page "/sectors"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@inject ISectorService SectorService
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<PageTitle>Sektörler</PageTitle>

<MudText Typo="Typo.h5" Class="mb-4">Sektörler</MudText>

<MudPaper Class="pa-4 mb-4">
    <MudGrid>
        <MudItem xs="12" Class="d-flex align-center justify-end">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                Yeni Sektör
            </MudButton>
        </MudItem>
    </MudGrid>
</MudPaper>

<MudDataGrid T="SectorResponse" Items="_items" Loading="_loading"
             SortMode="SortMode.None" Filterable="false" Dense="true">
    <Columns>
        <PropertyColumn Property="x => x.Name" Title="Sektör Adı" />
        <TemplateColumn Title="Durum" CellStyle="width:100px">
            <CellTemplate>
                <MudChip T="string" Size="Size.Small"
                         Color="@(context.Item.IsActive ? Color.Success : Color.Default)">
                    @(context.Item.IsActive ? "Aktif" : "Pasif")
                </MudChip>
            </CellTemplate>
        </TemplateColumn>
        <PropertyColumn Property="x => x.TenantCount" Title="Firma Sayısı" CellStyle="width:130px" />
        <TemplateColumn Title="İşlemler" CellStyle="width:120px">
            <CellTemplate>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => OpenEditDialog(context.Item))" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                               Color="Color.Error"
                               OnClick="@(() => DeleteSectorAsync(context.Item))" />
            </CellTemplate>
        </TemplateColumn>
    </Columns>
    <NoRecordsContent>
        <MudText>Kayıt bulunamadı.</MudText>
    </NoRecordsContent>
</MudDataGrid>

@code {
    private IEnumerable<SectorResponse> _items = Enumerable.Empty<SectorResponse>();
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        await LoadSectors();
    }

    private async Task LoadSectors()
    {
        _loading = true;
        try
        {
            var result = await SectorService.GetSectorsAsync();
            _items = result ?? Enumerable.Empty<SectorResponse>();
        }
        finally { _loading = false; }
    }

    private async Task OpenCreateDialog()
    {
        var model = new CreateSectorRequest();
        var parameters = new DialogParameters<SectorFormDialog>
        {
            { x => x.IsEdit, false },
            { x => x.Model, model }
        };
        var dialog = await DialogService.ShowAsync<SectorFormDialog>("Yeni Sektör", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var req = (CreateSectorRequest)result.Data!;
            var created = await SectorService.CreateSectorAsync(req);
            if (created is not null)
            {
                Snackbar.Add("Sektör oluşturuldu.", Severity.Success);
                await LoadSectors();
            }
        }
    }

    private async Task OpenEditDialog(SectorResponse sector)
    {
        var model = new UpdateSectorRequest { Name = sector.Name, IsActive = sector.IsActive };
        var parameters = new DialogParameters<SectorFormDialog>
        {
            { x => x.IsEdit, true },
            { x => x.UpdateModel, model }
        };
        var dialog = await DialogService.ShowAsync<SectorFormDialog>("Sektörü Düzenle", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var req = (UpdateSectorRequest)result.Data!;
            var updated = await SectorService.UpdateSectorAsync(sector.Id, req);
            if (updated is not null)
            {
                Snackbar.Add("Sektör güncellendi.", Severity.Success);
                await LoadSectors();
            }
        }
    }

    private async Task DeleteSectorAsync(SectorResponse sector)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, $"'{sector.Name}' sektörü silinecek. Emin misiniz?" }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Onayla", parameters);
        var result = await dialog.Result;
        if (!result.Canceled)
        {
            var success = await SectorService.DeleteSectorAsync(sector.Id);
            if (success)
            {
                Snackbar.Add("Sektör silindi.", Severity.Success);
                await LoadSectors();
            }
        }
    }
}
